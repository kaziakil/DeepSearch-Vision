# App
APP_NAME=DeepSearch-Vision
APP_ENV=development
DEBUG=true

# Storage
STORAGE_RAW=storage/raw
STORAGE_CHUNKS=storage/chunks

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=deepsearch

# Models
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-base
VLM_MODEL=Qwen/Qwen2-VL-2B-Instruct

# Retrieval
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FINAL=5


